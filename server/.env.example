# Octopus AI - Environment Variables
# انسخ هذا الملف إلى .env وأضف مفاتيح API الخاصة بك

# Groq API (مجاني وقوي)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API (للنماذج المجانية)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Gemini API (Google)
GEMINI_API_KEY=your_gemini_api_key_here

# Mistral API
MISTRAL_API_KEY=your_mistral_api_key_here

# Cohere API
COHERE_API_KEY=your_cohere_api_key_here

# Together AI API
TOGETHER_API_KEY=your_together_api_key_here

# CodeGeeX API (مزود AI من الإضافات)
CODEGEEX_API_KEY=your_codegeex_api_key_here

# Server Port
PORT=3001

# Local API protection
# When set, every /api/* request must include this value in X-Octopus-Token.
OCTOPUS_API_TOKEN=change_this_local_token

# Optional development-only bypass for loopback requests.
# Keep disabled unless you intentionally want unauthenticated local API access.
OCTOPUS_ALLOW_LOCAL_NO_AUTH=0
